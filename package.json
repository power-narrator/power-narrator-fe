{
  "name": "ppt-viewer",
  "version": "0.4.2",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:electron && node -e \"require('fs').writeFileSync('dist-electron/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\" && concurrently -k \"tsc -p electron -w\" \"electron .\"",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "tsc -p electron",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "lint": "eslint",
    "format": "oxfmt",
    "preview": "vite preview",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@mantine/core": "^8.3.18",
    "@tabler/icons-react": "^3.41.0",
    "dotenv": "^17.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "oxfmt": "^0.42.0",
    "playwright": "^1.58.2",
    "pptxgenjs": "^4.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  }
}
