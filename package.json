{
  "name": "power-narrator",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run dev:electron\"",
    "dev:electron": "npm run build:electron && concurrently -k \"tsc -p electron -w\" \"electron .\"",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "tsc -p electron",
    "dist": "npm run build && electron-builder",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@gfazioli/mantine-split-pane": "^3.0.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@mantine/core": "^8.3.18",
    "@tabler/icons-react": "^3.41.1",
    "dotenv": "^17.4.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "globals": "^17.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "pptxgenjs": "^4.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.3"
  }
}
