{
    "appId": "com.norbertloh.pptviewer",
    "productName": "PPT Viewer",
    "files": [
        "dist-vite",
        "dist-electron"
    ],
    "extraResources": [
        "electron/scripts/**/*"
    ],
    "mac": {
        "target": "dmg",
        "hardenedRuntime": true,
        "gatekeeperAssess": false
    },
    "asar": true,
    "asarUnpack": [
        "**/*.scpt",
        "**/*.applescript",
        "**/*.bas",
        "**/*.vba"
    ]
}